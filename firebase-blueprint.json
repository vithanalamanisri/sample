{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile information and career settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Resume": {
      "title": "Resume",
      "description": "User resume data including experience, education, and skills",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "personalInfo": { "type": "object" },
        "experience": { "type": "array" },
        "education": { "type": "array" },
        "skills": { "type": "array" },
        "projects": { "type": "array" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document"
    },
    "/resumes/{resumeId}": {
      "schema": "Resume",
      "description": "Resume documents"
    }
  }
}
